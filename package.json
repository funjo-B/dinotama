{
  "name": "dinotama",
  "version": "0.1.0",
  "description": "Desktop Dinosaur Tamagotchi - 모니터 구석의 공룡 다마고치",
  "main": "dist/main/main/index.js",
  "author": "DinoTama Team",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "node scripts/electron-dev.js",
    "dev:web": "vite src/renderer",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "npm run build && electron-builder --mac",
    "start": "electron dist/main/main/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest"
  },
  "dependencies": {
    "@stripe/stripe-js": "^4.8.0",
    "dotenv": "^17.3.1",
    "electron-store": "^8.2.0",
    "firebase": "^10.14.0",
    "framer-motion": "^11.11.0",
    "googleapis": "^144.0.0",
    "node-notifier": "^10.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "canvas": "^3.2.3",
    "concurrently": "^9.1.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^9.14.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.1",
    "sharp": "^0.34.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  },
  "build": {
    "appId": "com.dinotama.app",
    "productName": "DinoTama",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": ".env",
        "to": ".env"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/assets/icons/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/assets/icons/icon.icns",
      "category": "public.app-category.games",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "protocols": {
      "name": "DinoTama",
      "schemes": [
        "dinotama"
      ]
    }
  }
}
